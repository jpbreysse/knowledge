# Local dev (matches the pgvector/pgvector:pg16 docker image used for development)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/asset_dev

# Where uploaded documents are stored (relative paths resolved from project root)
UPLOAD_DIR=./uploads

# adapter-node body size limit — must be >= 50 MB for document uploads.
# Value is in bytes. 52428800 = 50 * 1024 * 1024.
BODY_SIZE_LIMIT=52428800

# On Scalingo, DATABASE_URL is aliased to SCALINGO_POSTGRESQL_URL.
# SCALINGO_POSTGRESQL_URL=

# Base URL of the document-store SPA — finding descriptions are edited there
# (embedded iframe on /findings/[id]). Override per environment.
DOCS_APP_BASE=http://localhost:5173
